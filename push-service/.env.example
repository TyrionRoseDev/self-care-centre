# Copy these into Coolify's Environment Variables for the push-service.

# Generate once with:  npm run vapid
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:euanmorgan48@gmail.com

# Your app's origin, so the browser is allowed to call this service.
ALLOW_ORIGIN=https://ritual.yourdomain.com

# Timezone the reminder schedule runs in.
TZ=Europe/London

# Optional shared secret to protect the /test and /send endpoints.
ADMIN_TOKEN=

# Where subscriptions.json lives — mount a Coolify volume here so it persists.
DATA_DIR=/data

# Port the service listens on (Coolify maps this).
PORT=8080
